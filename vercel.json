{
    "crons": [
        {
            "path": "/api/cron/delete-old-orders",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/admin/orders/auto-cleanup",
            "schedule": "0 3 * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, no-cache, max-age=0, must-revalidate, proxy-revalidate"
                },
                {
                    "key": "Pragma",
                    "value": "no-cache"
                },
                {
                    "key": "Expires",
                    "value": "0"
                }
            ]
        }
    ]
}