# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paystack
PAYSTACK_SECRET_KEY=your_paystack_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# CodeCraft API (for AT-iShare, Telecel, AT-BigTime)
CODECRAFT_API_URL=https://api.codecraftnetwork.com/api
CODECRAFT_API_KEY=your_codecraft_api_key

# MTN API
MTN_API_KEY=your_mtn_api_key
MTN_API_BASE_URL=your_mtn_api_base_url

# Moolre SMS
MOOLRE_API_KEY=your_moolre_api_key
MOOLRE_SENDER_ID=GHData
SMS_ENABLED=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your_cron_secret
