# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paystack
PAYSTACK_SECRET_KEY=your_paystack_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# CodeCraft API (for AT-iShare, Telecel, AT-BigTime)
CODECRAFT_API_URL=https://api.codecraftnetwork.com/api
CODECRAFT_API_KEY=your_codecraft_api_key

# DataKazina API Configuration
DATAKAZINA_API_KEY=your_datakazina_api_key_here
DATAKAZINA_API_BASE_URL=https://reseller.dakazinabusinessconsult.com/api/v1

# Auto-Fulfillment Toggle (set to 'false' to disable auto-fulfillment)
# When disabled, orders stay as 'pending' for manual processing
ENABLE_AUTO_FULFILLMENT=true

# Moolre SMS
MOOLRE_API_KEY=your_moolre_api_key
MOOLRE_SENDER_ID=ARHMS
SMS_ENABLED=true

# Moolre Transfer API (for automated shop withdrawals — separate from SMS)
# Get these from your Moolre dashboard: https://app.moolre.com
MOOLRE_TRANSFER_API_USER=your_moolre_username
MOOLRE_TRANSFER_API_KEY=your_moolre_transfer_api_key
MOOLRE_ACCOUNT_NUMBER=your_moolre_account_number

# Feature Flags
NEXT_PUBLIC_PAYMENT_MAINTENANCE_MODE=false

# App
NEXT_PUBLIC_APP_URL=https://arhmsdata.com
CRON_SECRET=your_cron_secret
CRON_JOBS_ENABLED=false

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL="your-upstash-redis-rest-url-here"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token-here"
